generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  SUPERVISOR
  ACCOUNT_MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum KioskStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum ProductType {
  EMAIL
  MAGNET
  OTHERS
  CERTIFICATE_LEFT_1
  CERTIFICATE_LEFT_2
  CERTIFICATE_RIGHT_1
}

enum ComboStatus {
  ACTIVE
  INACTIVE
}

enum FrameStatus {
  ACTIVE
  INACTIVE
}

enum ObjectStatus {
  ACTIVE
  INACTIVE
}

enum PaymentType {
  CASH
  CARD
  QR
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  staffCode        String     @unique
  name             String
  username         String     @unique
  passwordHash     String
  email            String     @unique
  phone            String?
  locationArea     String?
  role             UserRole   @default(STAFF)
  deletePermission Boolean    @default(false)
  profileImageUrl  String?
  status           UserStatus @default(ACTIVE)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  orders      Order[]      @relation("StaffOrders")
  orderPhotos OrderPhoto[] @relation("PhotographerPhotos")

  @@index([username])
  @@index([role])
  @@index([status])
  @@map("users")
}

model Kiosk {
  id              String      @id @default(uuid())
  name            String
  username        String      @unique
  passwordHash    String
  description     String?     @db.Text
  profileImageUrl String?
  status          KioskStatus @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  orders Order[]

  @@index([username])
  @@index([status])
  @@map("kiosks")
}

model Size {
  id        String   @id @default(uuid())
  height    Decimal  @db.Decimal(10, 2)
  width     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("sizes")
}

model Product {
  id          String        @id @default(uuid())
  name        String
  price       Decimal       @db.Decimal(10, 2)
  description String?       @db.Text
  productType ProductType   @default(OTHERS)
  photoLimit  Int           @default(1)
  sizeId      String?
  imageUrl    String?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  size        Size?              @relation(fields: [sizeId], references: [id])
  comboItems  ComboProductItem[]
  orderPhotos OrderPhoto[]

  @@index([sizeId])
  @@index([status])
  @@index([productType])
  @@map("products")
}

model ComboProduct {
  id           String      @id @default(uuid())
  name         String
  price        Decimal     @db.Decimal(10, 2)
  description  String?     @db.Text
  thumbnailUrl String?
  status       ComboStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items       ComboProductItem[]
  orderCombos OrderCombo[]

  @@index([status])
  @@map("combo_products")
}

model ComboProductItem {
  id             String @id @default(uuid())
  comboProductId String
  productId      String
  quantity       Int    @default(1)

  comboProduct ComboProduct @relation(fields: [comboProductId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@unique([comboProductId, productId])
  @@index([comboProductId])
  @@index([productId])
  @@map("combo_product_items")
}

model Discount {
  id          String   @id @default(uuid())
  code        String   @unique
  amount      Decimal  @db.Decimal(10, 2)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]

  @@index([code])
  @@map("discounts")
}

model Frame {
  id        String      @id @default(uuid())
  name      String
  imageUrl  String?
  status    FrameStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orderPhotos OrderPhoto[]

  @@index([status])
  @@map("frames")
}

model ObjectMaster {
  id          String       @id @default(uuid())
  title       String
  description String?      @db.Text
  imageUrl    String?
  status      ObjectStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ultraItems UltraObjectItem[]

  @@index([status])
  @@map("object_masters")
}

model UltraObject {
  id          String       @id @default(uuid())
  title       String
  description String?      @db.Text
  imageUrl    String?
  status      ObjectStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items UltraObjectItem[]

  @@index([status])
  @@map("ultra_objects")
}

model UltraObjectItem {
  id            String @id @default(uuid())
  ultraObjectId String
  objectId      String

  ultraObject UltraObject  @relation(fields: [ultraObjectId], references: [id], onDelete: Cascade)
  object      ObjectMaster @relation(fields: [objectId], references: [id])

  @@unique([ultraObjectId, objectId])
  @@index([ultraObjectId])
  @@index([objectId])
  @@map("ultra_object_items")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id            String        @id @default(uuid())
  orderCode     String        @unique
  kioskId       String
  staffId       String
  discountId    String?
  date          DateTime      @db.Date
  time          String
  paymentType   PaymentType   @default(CASH)
  price         Decimal       @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  kiosk       Kiosk        @relation(fields: [kioskId], references: [id])
  staff       User         @relation("StaffOrders", fields: [staffId], references: [id])
  discount    Discount?    @relation(fields: [discountId], references: [id])
  orderCombos OrderCombo[]

  @@index([kioskId])
  @@index([staffId])
  @@index([discountId])
  @@index([paymentStatus])
  @@index([date])
  @@map("orders")
}

model OrderCombo {
  id                  String   @id @default(uuid())
  orderId             String
  comboProductId      String
  comboCode           String
  priceSnapshot       Decimal  @db.Decimal(10, 2)
  descriptionSnapshot String?  @db.Text
  createdAt           DateTime @default(now())

  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  comboProduct ComboProduct @relation(fields: [comboProductId], references: [id])
  orderPhotos  OrderPhoto[]

  @@index([orderId])
  @@index([comboProductId])
  @@map("order_combos")
}

model OrderPhoto {
  id             String   @id @default(uuid())
  orderComboId   String
  productId      String?
  photographerId String?
  frameId        String?
  folderLabel    String?
  imageUrl       String
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  orderCombo   OrderCombo   @relation(fields: [orderComboId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id])
  photographer User?        @relation("PhotographerPhotos", fields: [photographerId], references: [id])
  frame        Frame?       @relation(fields: [frameId], references: [id])

  @@index([orderComboId])
  @@index([productId])
  @@index([photographerId])
  @@index([frameId])
  @@index([expiresAt])
  @@map("order_photos")
}
