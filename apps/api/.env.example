# Copy to apps/api/.env and fill in your values

NODE_ENV=development
API_PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

DATABASE_URL=mysql://facecraft:password@127.0.0.1:3306/facecraft
SESSION_SECRET=replace-with-at-least-32-random-bytes-here

# AWS S3 (required)
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=facecraft-private-photos
REKOGNITION_COLLECTION_ID=facecraft-photos

PHOTO_RETENTION_DAYS=7
SIGNED_URL_TTL_SECONDS=300
KIOSK_SESSION_TTL_MINUTES=30
FACE_MATCH_THRESHOLD=80

# Local dev only — use IAM role on EC2 in production
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Admin sidebar logo (upload PNG to this S3 key first)
# Login + home vertical logo
BRAND_LOGO_S3_KEY=branding/facecraft-brand-logo.png
# Admin sidebar + photographer topbar horizontal logo
BRAND_ADMIN_LOGO_S3_KEY=branding/facecraft-admin-logo.png
BRAND_SPINNER_S3_KEY=branding/facecraft-spinner-emblem.png

# Kiosk home hero video (upload to kiosk/home/ in S3)
KIOSK_HOME_VIDEO_S3_KEY=kiosk/home/kiosk-home-hero.mp4

# Set to false to hide demo login hints on admin/kiosk login pages
SHOW_DEMO_CREDENTIALS=true
