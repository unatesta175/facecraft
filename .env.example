# Application
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL=mysql://facecraft:password@127.0.0.1:3306/facecraft

# Security
SESSION_SECRET=replace-with-at-least-32-random-bytes-in-production

# AWS Configuration
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=facecraft-private-photos
REKOGNITION_COLLECTION_ID=facecraft-photos

# Feature Configuration
PHOTO_RETENTION_DAYS=7
SIGNED_URL_TTL_SECONDS=300
KIOSK_SESSION_TTL_MINUTES=30

# AWS Credentials (Only for local development - Use IAM role in EC2)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
